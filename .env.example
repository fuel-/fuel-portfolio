# Contact-form email notifications via Resend's HTTPS API.
# Copy to .env on the server and fill in — `cp .env.example .env`.
# If any value is blank, the app skips email and just saves inquiries to the db.
SMTP_PASS=re_your_api_key_here        # Resend API key
SMTP_FROM=contact@contact.gideon.gg   # must be on your Resend-verified domain
SMTP_TO=jasen.nicely@proton.me        # inbox that receives the notification
