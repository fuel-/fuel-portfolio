# Contact-form email notifications (Resend SMTP).
# Copy to .env on the server and fill in — `cp .env.example .env`.
# If any value is blank, the app skips email and just saves inquiries to the db.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here
SMTP_FROM=contact@yourdomain.com
SMTP_TO=jasen.nicely@proton.me
